---
import BaseLayout from "../layouts/BaseLayout.astro";
import HiddenTextBlock from "../components/HiddenTextBlock.astro";
---

<BaseLayout title="隐藏文字块演示" description="HiddenTextBlock 组件效果展示">
  <header class="masthead" style="padding: 6rem 0 4rem; text-align: center;">
    <div class="container">
      <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">HiddenTextBlock</h1>
    </div>
  </header>

  <main class="container px-4 px-lg-5" style="padding-bottom: 4rem;">
    <div class="row justify-content-center">
      <div class="col-md-10 col-lg-8 col-xl-7">

        <section style="margin-bottom: 3rem;">
          <h2 style="font-size: 1.3rem; margin-bottom: 1rem; color: #ccc;">
            1. blur（模糊效果）— 鼠标悬停
          </h2>
          <HiddenTextBlock
            effect="blur"
            trigger="hover"
            content={`1`}
          />
        </section>

        <section style="margin-bottom: 3rem;">
          <h2 style="font-size: 1.3rem; margin-bottom: 1rem; color: #ccc;">
            2. blackout（涂黑效果）— 鼠标悬停
          </h2>
          <HiddenTextBlock
            effect="blackout"
            trigger="hover"
            content={`2`}
          />
        </section>

        <section style="margin-bottom: 3rem;">
          <h2 style="font-size: 1.3rem; margin-bottom: 1rem; color: #ccc;">
            3. fade（淡入效果）— 鼠标悬停
          </h2>
          <HiddenTextBlock
            effect="fade"
            trigger="hover"
            content={`3`}
          />
        </section>

        <section style="margin-bottom: 3rem;">
          <h2 style="font-size: 1.3rem; margin-bottom: 1rem; color: #ccc;">
            4. mask（遮罩效果）— 鼠标悬停
          </h2>
          <HiddenTextBlock
            effect="mask"
            trigger="hover"
            content={`4`}
          />
        </section>

        <section style="margin-bottom: 3rem;">
          <h2 style="font-size: 1.3rem; margin-bottom: 1rem; color: #ccc;">
            5. click（点击切换）— 任意效果
          </h2>
          <HiddenTextBlock
            effect="blur"
            trigger="click"
            content={`5`}
          />
        </section>

        <hr style="border-color: #333; margin: 3rem 0;" />

        <section>
          <h2 style="font-size: 1.3rem; margin-bottom: 1rem; color: #ccc;">使用方法</h2>
          <pre style="background: #1e1e1e; padding: 1.2rem; border-radius: 8px; overflow-x: auto; font-size: 0.8rem;"><code style="color: #d4d4d4;">---
import HiddenTextBlock from "../components/HiddenTextBlock.astro";
---

&lt;HiddenTextBlock
  effect="blur"        &lt;!-- blur | blackout | fade | mask --&gt;
  trigger="hover"      &lt;!-- hover | click --&gt;
  content={`被隐藏的文本内容……`}
/&gt;</code></pre>
        </section>

      </div>
    </div>
  </main>
</BaseLayout>
