<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  :global(body) {
    font-family: "Noto Serif SC", "Songti SC", serif;
    background: #0a0a0a;
    color: #e0e0e0;
    overflow-x: hidden;
    scroll-behavior: smooth;
  }

  :global(.navbar) {
    background: transparent !important;
  }

  .chapter {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 10vh 10vw;
    overflow: hidden;
  }

  .content {
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.9;
    font-size: 1.15rem;
    position: relative;
    z-index: 2;
    background: rgba(10, 10, 10, 0.9);
    padding: 3rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .content p { 
    margin-bottom: 1.8em; 
    text-align: justify; 
  }

  /* ============================================
     第一章：泰勒斯 - 星盘与日食
     ============================================ */
  .chapter-1 {
    background: radial-gradient(ellipse at center, #0f172a 0%, #020617 100%);
  }
  
  .celestial-device {
    position: absolute;
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
    width: 400px;
    height: 400px;
    pointer-events: none;
    opacity: 0.8;
    filter: drop-shadow(0 0 30px rgba(184, 115, 51, 0.3));
  }

  .celestial-device::before {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    border: 2px solid rgba(184, 115, 51, 0.4);
    border-radius: 50%;
    background: 
      repeating-conic-gradient(from 0deg at 50% 50%, 
        transparent 0deg, 
        rgba(184, 115, 51, 0.1) 1deg, 
        transparent 2deg);
    animation: rotate 120s linear infinite;
  }

  .zodiac-ring {
    position: absolute;
    top: 10%; left: 10%;
    width: 80%; height: 80%;
    border: 1px dashed rgba(184, 115, 51, 0.3);
    border-radius: 50%;
    animation: rotate 60s linear infinite reverse;
  }

  .eclipse {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 120px; height: 120px;
    background: radial-gradient(circle, #000 40%, transparent 70%);
    border-radius: 50%;
    box-shadow: 
      0 0 60px rgba(255, 200, 100, 0.6),
      inset 0 0 20px rgba(184, 115, 51, 0.8);
    animation: eclipse-pulse 4s ease-in-out infinite;
  }

  .corona {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 140px; height: 140px;
    border: 3px solid rgba(255, 215, 0, 0.6);
    border-radius: 50%;
    filter: blur(8px);
    animation: corona-rotate 20s linear infinite;
  }

  @keyframes rotate { 
    from { transform: rotate(0deg); } 
    to { transform: rotate(360deg); } 
  }
  
  @keyframes eclipse-pulse {
    0%, 100% { box-shadow: 0 0 60px rgba(255, 200, 100, 0.6), inset 0 0 20px rgba(184, 115, 51, 0.8); }
    50% { box-shadow: 0 0 100px rgba(255, 200, 100, 0.9), inset 0 0 30px rgba(184, 115, 51, 1); }
  }
  
  @keyframes corona-rotate {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* ============================================
     第二章：柏拉图 - 黄金几何与大理石
     ============================================ */
  .chapter-2 {
    background: linear-gradient(135deg, #2a2520 0%, #1a1814 100%);
