---
import StylizedLayout from "../../layouts/StylizedLayout.astro";

const BASE = import.meta.env.BASE_URL || '/';
---

<StylizedLayout
  title="洛穹偎的一家言 - 我的百合从夯到拉"
  description="从夯到拉，来排榜！"
  style={["from-pounding.css"]}
>
    
    <!-- 主内容区 -->
    <div class="main-container">
        <br><br><br>
        <h2>我看过的...从夯到拉</h2>
        <table id="1">
            <tr>   
                <th class="base-block first-block">夯</th>
                <td class="data-block drop-zone" data-level="1">
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/明天，美食广场见。.jpg`} alt="明天，美食广场见。"><span class="img-cover" data-comment="用一个季度的十多集动画讲好一个故事是一个比较容易的事情，相较而言，片段式地每集讲好一个甚至好几个短故事，就要难得多了。更难能可贵的是，这部番只有短短六集，却借由它的每集两三个短故事传递出了许多引人思考的内容。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/赛马娘 Pretty Derby 第二季.jpg`} alt="赛马娘 Pretty Derby 第二季"><span class="img-cover" data-comment="毋庸置疑地动人心弦，每一次看到东海帝皇冲线这段剧情，无论是泛式的MMD，当年实拍的视频，或者是动画中这一段的呈现，都忍不住流出泪来。没有什么比这更能展现拼搏的精神了。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/少女终末旅行.jpg`} alt="少女终末旅行"><span class="img-cover" data-comment="同样是片段化的叙事，对于末世的想象与讨论引人深思。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/GIRLS BAND CRY.jpg`} alt="GIRLS BAND CRY"><span class="img-cover" data-comment="最妙的王道系乐队番，结尾的留白更为巧妙。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/上伊那牡丹，酒醉身姿似百合花般.jpg`} alt="上伊那牡丹，酒醉身姿似百合花般"><span class="img-cover" data-comment="真白里最不胃痛的一部。珍肴异馔。"></span></span>
                </td>
            </tr>
            <tr>
                <th class="base-block second-block">顶尖</th>
                <td class="data-block drop-zone" data-level="2">
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/孤独摇滚！.jpg`} alt="孤独摇滚！"><span class="img-cover" data-comment="何为孤独？也许我们都可以在其中找到共鸣。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/琉璃的宝石.jpg`} alt="琉璃的宝石"><span class="img-cover" data-comment="最好的科普番，剧情紧凑。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/时光流逝，饭菜依旧美味.jpg`} alt="时光流逝，饭菜依旧美味"><span class="img-cover" data-comment="轻松的日常，同时心中怀有小小的梦想。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/摇曳露营△.jpg`} alt="摇曳露营△"><span class="img-cover" data-comment="剧情与音乐让人感到舒适无比。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/对我垂涎欲滴的非人少女.jpg`} alt="对我垂涎欲滴的非人少女"><span class="img-cover" data-comment="放在这里纯属私心。我喜欢它的设定。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/我们不可能成为恋人！绝对不行。 (※似乎可行？).jpg`} alt="我们不可能成为恋人！绝对不行。"><span class="img-cover" data-comment="开创了一种新的类型。直白但真挚。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/牵牛花与加濑同学。.jpg`} alt="牵牛花与加濑同学。"><span class="img-cover" data-comment="真百里越不胃痛的我就把排名放的越高。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/安达与岛村.jpg`} alt="安达与岛村"><span class="img-cover" data-comment="真百里越不胃痛的我就把排名放的越高。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/终将成为你.jpg`} alt="终将成为你"><span class="img-cover" data-comment="真百里越不胃痛的我就把排名放的越高。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/小林家的龙女仆.jpg`} alt="小林家的龙女仆"><span class="img-cover" data-comment="有趣的搞笑日常番。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/请问您今天要来点兔子吗？.jpg`} alt="请问您今天要来点兔子吗？"><span class="img-cover" data-comment="可可爱爱、轻轻松松。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/BanG Dream!.jpg`} alt="BanG Dream!"><span class="img-cover" data-comment="给老前辈一些尊重，可惜后辈们越来越把良好的品质丢掉了。"></span></span>
                </td>
            </tr>
            <tr>
                <th class="base-block third-block">人上人</th>
                <td class="data-block drop-zone" data-level="3">
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/超时空辉夜姬！.jpg`} alt="超时空辉夜姬！"><span class="img-cover" data-comment="过誉。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/向山进发.jpg`} alt="向山进发"><span class="img-cover" data-comment="泡面番。第一部的情节也确实不算很出众。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/梦想成为魔法少女.jpg`} alt="梦想成为魔法少女"><span class="img-cover" data-comment="保护性排位。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/赛马娘 Pretty Derby.jpg`} alt="赛马娘 Pretty Derby"><span class="img-cover" data-comment="不好不坏，无功无过。"></span></span>
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/BanG Dream! It's MyGO!!!!!.jpg`} alt="BanG Dream! It's MyGO!!!!!"><span class="img-cover" data-comment="咕咕嘎嘎！"></span></span>
                </td>
            </tr>
            <tr>
                <th class="base-block fourth-block">NPC</th>
                <td class="data-block drop-zone" data-level="4">
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/BanG Dream! Ave Mujica.jpg`} alt="BanG Dream! Ave Mujica"><span class="img-cover" data-comment="为爆而爆"></span></span>
                </td>
            </tr>
            <tr>
                <th class="base-block fifth-block">拉完了</th>
                <td class="data-block drop-zone" data-level="5">
                    <span class="img-wrapper"><img src={`${BASE}assets/img/bangumi/神椿市建设中。.jpg`} alt="神椿市建设中。"><span class="img-cover" data-comment="什么玩意儿，扭曲，怪诞。监督肯定是疯了，照着游戏抄都不至于成这样。"></span></span>
                </td>
            </tr>
        </table>


    </div>

    <div id="comment-modal" class="comment-modal hidden">
        <div class="comment-modal-backdrop"></div>
        <div class="comment-modal-content">
            <button class="comment-modal-close" aria-label="关闭">&times;</button>
            <div class="comment-modal-body">
                <div class="comment-modal-image-wrapper">
                    <img class="comment-modal-image" id="modal-image" src="" alt="">
                </div>
                <div class="comment-modal-text" id="modal-text"></div>
            </div>
        </div>
    </div>

<p>也想创作你的从夯到拉？前往<a href="../from-pounding-to-sharp-criticism/">创作页面</a></p>


    <script is:inline>
        document.addEventListener('DOMContentLoaded', function () {
            var modal = document.getElementById('comment-modal');
            var modalImage = document.getElementById('modal-image');
            var modalText = document.getElementById('modal-text');
            var closeBtn = modal.querySelector('.comment-modal-close');
            var backdrop = modal.querySelector('.comment-modal-backdrop');

            function openModal(src, alt, comment) {
                modalImage.src = src;
                modalImage.alt = alt || '';
                modalText.textContent = comment || '暂无评价';
                modal.classList.remove('hidden');
                // 强制重排以触发 transition
                void modal.offsetWidth;
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            function closeModal() {
                modal.classList.remove('active');
                setTimeout(function () {
                    modal.classList.add('hidden');
                    modalImage.src = '';
                    document.body.style.overflow = '';
                }, 300);
            }

            document.querySelectorAll('.img-cover').forEach(function (cover) {
                cover.addEventListener('click', function () {
                    var img = cover.parentElement.querySelector('img');
                    if (img) {
                        openModal(img.src, img.alt, cover.dataset.comment);
                    }
                });
            });

            closeBtn.addEventListener('click', closeModal);
            backdrop.addEventListener('click', closeModal);
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && modal.classList.contains('active')) {
                    closeModal();
                }
            });
        });
    </script>

</StylizedLayout>

<style>
    .img-wrapper {
        position: relative;
        display: inline-flex;
        align-items: flex-start;
        vertical-align: top;
    }
    .img-cover {
        position: absolute;
        inset: 0;
        z-index: 5;
        cursor: pointer;
        border-radius: 5px;
        transition: box-shadow 0.2s ease;
    }

    /* 评价弹窗 */
    .comment-modal {
        position: fixed;
        inset: 0;
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
    }
    .comment-modal.active {
        opacity: 1;
        visibility: visible;
    }
    .comment-modal.hidden {
        display: none;
    }
    .comment-modal-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
    }
    .comment-modal-content {
        position: relative;
        background: var(--table-bg, rgba(255, 255, 255, 0.95));
        border-radius: 16px;
        box-shadow: 0 25px 80px rgba(0, 0, 0, 0.35);
        max-width: 800px;
        width: 100%;
        max-height: 90vh;
        overflow: auto;
        transform: scale(0.85) translateY(20px);
        transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .comment-modal.active .comment-modal-content {
        transform: scale(1) translateY(0);
    }
    .comment-modal-close {
        position: absolute;
        top: 12px;
        right: 16px;
        background: none !important;
        border: none !important;
        font-size: 32px;
        line-height: 1;
        cursor: pointer;
        color: var(--text-color, #333);
        z-index: 10;
        width: auto !important;
        padding: 0 !important;
        margin: 0 !important;
        box-shadow: none !important;
        transition: transform 0.2s ease;
    }
    .comment-modal-close:hover {
        transform: scale(1.1);
    }
    .comment-modal-body {
        display: flex;
        gap: 28px;
        padding: 36px;
    }
    .comment-modal-image-wrapper {
        flex: 0 0 240px;
        display: flex;
        align-items: flex-start;
        justify-content: center;
    }
    .comment-modal-image {
        max-width: 240px;
        max-height: 320px;
        width: auto;
        height: auto;
        object-fit: contain;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
        animation: modalImagePop 0.45s ease;
    }
    @keyframes modalImagePop {
        0% { transform: scale(0.5); opacity: 0; }
        70% { transform: scale(1.08); opacity: 1; }
        100% { transform: scale(1); }
    }
    .comment-modal-text {
        flex: 1 1 auto;
        font-size: 16px;
        line-height: 1.9;
        color: var(--text-color, #333);
        white-space: pre-wrap;
    }

    /* 移动端适配 */
    @media screen and (max-width: 768px) {
        .comment-modal-body {
            flex-direction: column;
            padding: 24px;
            gap: 20px;
        }
        .comment-modal-image-wrapper {
            flex: 0 0 auto;
        }
        .comment-modal-image {
            max-width: 160px;
            max-height: 220px;
        }
        .comment-modal-text {
            font-size: 15px;
        }
    }
</style>